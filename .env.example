# Convex — run `bunx convex dev` once to populate these
EXPO_PUBLIC_CONVEX_URL=

# Convex Auth — generated by `bunx convex env set` during auth setup
CONVEX_AUTH_ADAPTER=
CONVEX_AUTH_PRIVATE_KEY=
CONVEX_AUTH_JWKS=

# OAuth — register apps in Google/Apple consoles and paste here
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_APPLE_ID=
AUTH_APPLE_SECRET=

# Resend — parent approval emails (Phase 1)
RESEND_API_KEY=

# OpenAI API — AI insights (Phase 3)
OPENAI_API_KEY=

# Sentry — error monitoring (Phase 1)
EXPO_PUBLIC_SENTRY_DSN=

# PostHog — analytics (Phase 1, self-hosted EU)
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=
